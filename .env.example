# ── Project ───────────────────────────────────────────────────────────────────
PROJECT_NAME="ML FastAPI Service"
VERSION="1.0.0"
DEBUG=True

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5610

# ── Database ──────────────────────────────────────────────────────────────────
# Harus menunjuk ke MySQL yang sama dengan Laravel (koperasi6G)
DATABASE_URL=mysql://root:@localhost:3306/db_koperasi

# ── ML Model ──────────────────────────────────────────────────────────────────
MODEL_DIR=models/saved
MODEL_NAME=model.joblib

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=default
